{
  "manifest_version": 3,
  "name": "HMS Cheat Sheet Generator",
  "version": "0.1.0",
  "description": "Extract content from docs and generate exam cheat sheets.",
  "action": {
    "default_title": "HMS",
    "default_popup": "popup.html"
  },
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "assets/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle"
    }
  ]
}
